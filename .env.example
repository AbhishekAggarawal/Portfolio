# =============================================================================
# RAG Pipeline — Cloud Deployment Environment Variables
# =============================================================================
# LOCAL DEV:  Copy this file to .env.local. Fill in the values for your setup.
# PRODUCTION: Set these in your Vercel dashboard → Settings → Environment Variables.
#             Do NOT commit .env.local to GitHub.
#
# TWO DEPLOYMENT PATHS (see RAG_DEPLOYMENT.md for full guide):
#
#   PATH A — FREE ($0/month, 5 min setup):
#     ☐ GROQ_API_KEY        — from https://console.groq.com/keys (free, no card)
#     ☐ EMAIL_USER          — your Gmail address for contact form
#     ☐ EMAIL_PASSWORD      — 16-char App Password (Google → App Passwords)
#     ☐ RECEIVER_EMAIL      — where form submissions go
#     That's it! The chatbot uses keyword + synonym + intent matching.
#     ChromaDB and OpenAI embeddings are NOT needed for Path A.
#
#   PATH B — VECTOR SEARCH (~$7/mo, better quality):
#     All of Path A PLUS:
#     ☐ CHROMA_URL          — your Render ChromaDB URL (see render.yaml)
#     ☐ EMBEDDING_API_KEY   — from https://platform.openai.com/api-keys ($5 min)
#     ☐ EMBEDDING_API_URL   — https://api.openai.com/v1/embeddings
#     ☐ RAG_INGEST_TOKEN    — random secret for /api/ingest protection
#     ☐ RAG_TOP_K=5
# =============================================================================

# ── LLM (Groq Cloud) ──────────────────────────────────────────────────────
# REQUIRED (both paths). Get your free key: https://console.groq.com/keys
# No credit card needed. Generous free tier limits.
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings (Cloud — OpenAI) ───────────────────────────────────────────
# OPTIONAL. Only needed for Path B (vector search with ChromaDB).
# OpenAI text-embedding-3-small costs ~$0.02/1M tokens.
# SIGN UP at https://platform.openai.com → API Keys → requires $5 min pre-pay.
# Leave EMPTY if using Path A (free keyword fallback).
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=sk-your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=auto   # "auto" | "openai" | "ollama" — auto-detected

# ── Local Ollama (dev only — leave EMPTY in production!) ──────────────────
# Only used when EMBEDDING_API_URL is empty above.
# In production on Vercel, Ollama is NOT available.
OLLAMA_BASE_URL=http://localhost:11434

# ── Vector Database (ChromaDB) ────────────────────────────────────────────
# OPTIONAL. Only needed for Path B (vector search).
# When CHROMA_URL is empty/missing, the chatbot auto-falls back to keyword
# retrieval (synonym expansion + intent detection + exact-match boosting).
# See lib/rag/retrieval.ts for the full fallback pipeline.
#
# Path B setup:
#   1. Update render.yaml: change plan from "free" to "starter" ($7/mo)
#   2. Deploy on Render via Blueprint → copy the .onrender.com URL
#   3. Paste URL below + run: npx tsx scripts/ingest-cloud.ts
CHROMA_URL=http://localhost:8000
# CHROMA_TOKEN=              # Only if your Chroma instance has token auth enabled
CHROMA_COLLECTION=abhishek_portfolio

# ── Ingestion Token ────────────────────────────────────────────────────────
# OPTIONAL. Only needed for Path B (protects the /api/ingest endpoint).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
RAG_INGEST_TOKEN=change_this_to_a_random_secret_string
RAG_TOP_K=5

# ── Site URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Contact Form — Gmail + App Password) ───────────────────────────
# REQUIRED (both paths) for the /contact page form to work.
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" as the app and "Other" as the device, name it "Portfolio"
# 4. Copy the 16-character App Password (no spaces) → paste into EMAIL_PASSWORD
# 5. RECEIVER_EMAIL = where you want form submissions delivered
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
RECEIVER_EMAIL=your_email@gmail.com
