# =============================================================================
# RAG Pipeline — Cloud Deployment Environment Variables
# =============================================================================
# LOCAL DEV:  Copy this file to .env.local. Fill in the values for your setup.
# PRODUCTION: Set ALL of these in your Vercel dashboard → Settings → Environment Variables.
#             Do NOT commit .env.local to GitHub.
#
# QUICK CHECKLIST for production:
#   ☐ GROQ_API_KEY        — from https://console.groq.com/keys
#   ☐ EMBEDDING_API_KEY   — from https://platform.openai.com/api-keys
#   ☐ EMBEDDING_API_URL   — https://api.openai.com/v1/embeddings
#   ☐ CHROMA_URL          — your Render/Railway ChromaDB URL (see render.yaml)
#   ☐ RAG_INGEST_TOKEN    — random secret for /api/ingest protection
#   ☐ EMAIL_USER / EMAIL_PASSWORD / RECEIVER_EMAIL — for contact form
# =============================================================================

# ── LLM (Groq Cloud) ──────────────────────────────────────────────────────
# REQUIRED. Get your free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings (Cloud — OpenAI) ───────────────────────────────────────────
# REQUIRED for production. OpenAI text-embedding-3-small costs ~$0.02/1M tokens.
# SIGN UP at https://platform.openai.com → API Keys → create a key.
# You need to pre-pay $5 minimum the first time.
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=sk-your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=auto   # "auto" | "openai" | "ollama" — auto-detected

# ── Local Ollama (dev only — leave EMPTY in production!) ──────────────────
# Only used when EMBEDDING_API_URL is empty above.
# In production on Vercel, Ollama is NOT available — always use cloud embeddings.
OLLAMA_BASE_URL=http://localhost:11434

# ── Vector Database (ChromaDB) ────────────────────────────────────────────
# REQUIRED for production.
# STEP 1: Deploy ChromaDB on Render using render.yaml (one-click Blueprint):
#          https://render.com → New → Blueprint → connect your GitHub repo
# STEP 2: Copy the deployed URL (e.g., https://abhishek-chromadb.onrender.com)
# STEP 3: Paste it as CHROMA_URL below AND in Vercel env vars
CHROMA_URL=http://localhost:8000
# CHROMA_TOKEN=              # Only if your Chroma instance has token auth enabled
CHROMA_COLLECTION=abhishek_portfolio

# ── Ingestion Token ────────────────────────────────────────────────────────
# Secret token that protects the /api/ingest endpoint.
# Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
RAG_INGEST_TOKEN=change_this_to_a_random_secret_string
RAG_TOP_K=5

# ── Site URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Contact Form — Gmail + App Password) ───────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" as the app and "Other" as the device, name it "Portfolio"
# 4. Copy the 16-character App Password (no spaces) → paste into EMAIL_PASSWORD
# 5. RECEIVER_EMAIL = where you want form submissions delivered
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
RECEIVER_EMAIL=your_email@gmail.com
