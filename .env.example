# Email (Contact Form — Gmail + App Password)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" as the app and "Other" as the device, name it "Portfolio"
# 3. Copy the 16-character App Password (no spaces) into EMAIL_PASSWORD below
# 4. Set RECEIVER_EMAIL to the same or another address where you want form submissions
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
RECEIVER_EMAIL=your_email@gmail.com

# Qdrant Cloud Configuration
QDRANT_URL=https://<your-cluster-url>
QDRANT_API_KEY=<your-api-key>
